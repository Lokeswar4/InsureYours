# InsureYours — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored; this file is safe to commit.

# MySQL connection (used by etl_load.py, api.py, statistical_analysis.py, data_profiler.py)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=yourpassword

# Docker Compose default password (overrides the 'insureyours' default)
# Set this before running: export MYSQL_PASSWORD=yourpassword && docker compose up --build
